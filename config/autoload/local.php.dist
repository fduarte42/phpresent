<?php

declare(strict_types=1);

return [
    'debug' => (bool) getenv('APP_DEBUG'),
    'database' => [
        'url' => getenv('DATABASE_URL') ?: 'sqlite:///' . __DIR__ . '/../../data/phpresent.sqlite',
    ],
    'cache' => [
        'dsn' => getenv('CACHE_DSN') ?: 'array://',
    ],
    'songbookpro' => [
        // Confirmed live endpoint, SDD §6.1 — not a guess.
        'api_url' => getenv('SONGBOOKPRO_API_URL') ?: 'https://songbookpro-groups-prod.azurewebsites.net/graphql',
        // A per-install token issued out of band (SDD §6.3 — the real OAuth
        // grant a server-side client should use is still unresolved).
        'api_token' => getenv('SONGBOOKPRO_API_TOKEN') ?: '',
        // The `library` GraphQL variable in every `dataItems`/`addDataItems`
        // call (SDD §6.2) — a SongbookPro Groups library id, not an org id.
        'group_id' => getenv('SONGBOOKPRO_GROUP_ID') ?: '',
        'sync_interval_seconds' => (int) (getenv('SONGBOOKPRO_SYNC_INTERVAL_SECONDS') ?: 300),
        'rate_limit_per_second' => (int) (getenv('SONGBOOKPRO_RATE_LIMIT_PER_SECOND') ?: 5),
    ],
    'identity' => [
        // Only signs/verifies JWT bearer tokens for /api/* requests (session
        // auth is the default, see docs/sdd.md §18.2) — generate a real
        // secret for any environment where the JWT fallback is actually used.
        'jwt_secret' => getenv('IDENTITY_JWT_SECRET') ?: 'change-me-in-production-min-32-bytes-long',
        'jwt_algorithm' => getenv('IDENTITY_JWT_ALGORITHM') ?: 'HS256',
    ],
];
